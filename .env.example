# kanri-tool 環境変数テンプレート
# 値はリポジトリにコミットせず、ローカルは `.env.local`、本番は秘密管理サービスへ。
# 必須項目が欠落した状態で `npm run build` / `npm run dev` を実行すると
# src/shared/config/env.server.ts が起動時に検証エラーで停止する。

# -------- Prisma / PostgreSQL --------
# Prisma が業務 DB へ接続するための文字列。
# Supabase 利用時は connection pool 経由（ポート 6543, `?pgbouncer=true&connection_limit=1`）を推奨。
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# Prisma migrate（DDL）用の直接接続。pool を経由せず 5432 番ポートを使う。
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# -------- Supabase --------
# Supabase プロジェクト URL（クライアントにも公開される）。
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
# Supabase anon key（RLS 前提でクライアントへ公開可能）。
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-SUPABASE-ANON-KEY"
# Supabase service role key（サーバ専用 / 厳重管理 / クライアントへ絶対に出さない）。
SUPABASE_SERVICE_ROLE_KEY="YOUR-SUPABASE-SERVICE-ROLE-KEY"

# -------- 認証 / セッション --------
# 未操作で自動ログアウトされるまでの分数（既定 30）。
SESSION_IDLE_TIMEOUT_MIN=30
# 同一ログイン ID の連続認証失敗でロックする閾値（既定 5 回）。
LOGIN_LOCK_THRESHOLD=5
# ロック継続時間（分、既定 15）。
LOGIN_LOCK_DURATION_MIN=15

# -------- E2E（Playwright / 任意）--------
# ローカル: `.env.local` に設定後 `npm run build && npm run test:e2e`
# CI: `.github/workflows/e2e.yml` — リポジトリ Variable `E2E_ENABLED=true` と
#      下記アカウント Secrets を登録すると GitHub Actions で実行される。
# E2E_BASE_URL="http://127.0.0.1:3000"
# E2E_ADMIN_EMAIL="admin-login-id"
# E2E_ADMIN_PASSWORD="admin-password"
# E2E_STAFF_EMAIL="staff-login-id"
# E2E_STAFF_PASSWORD="staff-password"
# E2E_RESIDENT_ID="uuid-for-pdf-test"
